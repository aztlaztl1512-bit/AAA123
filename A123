    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap');
        body { font-family: 'Cairo', sans-serif; background: #f0f2f5; margin: 0; padding: 40px; }
        .report-paper { width: 210mm; min-height: 297mm; padding: 20px 40px; margin: auto; background: white; box-shadow: 0 0 10px rgba(0,0,0,0.1); position: relative; border: 1px solid #ddd; }
        .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #2c3e50; padding-bottom: 10px; margin-bottom: 30px; }
        .header-text { text-align: center; font-size: 14px; color: #2c3e50; }
        h1 { color: #1a5a96; text-align: center; text-decoration: underline; font-size: 24px; }
        .summary-box { background: #f9f9f9; border-right: 5px solid #1a5a96; padding: 15px; margin: 20px 0; }
        table { width: 100%; border-collapse: collapse; margin: 20px 0; }
        table, th, td { border: 1px solid #ccc; }
        th { background: #1a5a96; color: white; padding: 10px; }
        td { padding: 10px; text-align: center; }
        .chart-mockup { margin: 30px 0; text-align: center; }
        .progress-bar-container { background: #eee; border-radius: 10px; height: 25px; width: 100%; margin: 10px 0; overflow: hidden; }
        .progress-bar { background: linear-gradient(90deg, #27ae60, #2ecc71); height: 100%; width: 75%; text-align: center; color: white; line-height: 25px; font-weight: bold; }
        .footer { margin-top: 50px; display: flex; justify-content: space-between; }
        .signature { text-align: center; width: 200px; }
        .btn-print { background: #e74c3c; color: white; padding: 10px 25px; border: none; border-radius: 5px; cursor: pointer; font-family: 'Cairo'; font-weight: bold; position: fixed; top: 20px; left: 20px; }
        @media print { .btn-print { display: none; } body { padding: 0; background: white; } .report-paper { box-shadow: none; border: none; margin: 0; width: 100%; } }
    </style>
</head>
